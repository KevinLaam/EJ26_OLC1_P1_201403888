import java.util.LinkedList;
import ast.Instruccion;
import instrucciones.Declaracion;
import instrucciones.Println;
import expresiones.AccVariable;
import expresiones.Operacion;
import instrucciones.If;
import instrucciones.Asignacion;
import instrucciones.For;
import instrucciones.Break;
import instrucciones.Continue;
import instrucciones.Compuesta;
import instrucciones.FuncionNativa;
import java_cup.runtime.Symbol;
import reportes.ReporteE;
import instrucciones.Compuesta;
import instrucciones.Bloque;

//Para errores 

parser code
{:
    @Override
    public void syntax_error(java_cup.runtime.Symbol s) {
        //ReporteE.agregarError(
        //    "SINTACTICO",
        //    "Error sintáctico cerca de: " + s.value,
        //    s.left,
        //    s.right
        //);
    }

    @Override
    public void unrecovered_syntax_error(java_cup.runtime.Symbol s) throws Exception {
        ReporteE.agregarError(
            "SINTACTICO",
            "No se pudo recuperar del error sintáctico cerca de: " + s.value,
            s.left,
            s.right
        );
    }
:};



terminal FUNC, MAIN, VAR;
terminal IF, ELSE, FOR, BREAK, CONTINUE;

terminal INT, FLOAT64, STRING, BOOL, RUNE;
terminal TRUE, FALSE, NIL;

terminal PRINTLN, ATOI, PARSEFLOAT, TYPEOF, DOTSTRING;

terminal DECLARACION, MAS_IGUAL, MENOS_IGUAL;
terminal IGUAL, MAS, MENOS, POR, DIV, MOD;
terminal IGUAL_IGUAL, DIFERENTE, MENOR, MENOR_IGUAL, MAYOR, MAYOR_IGUAL;
terminal INCREMENTO, DECREMENTO;
terminal AND, OR, NOT;
terminal UMENOS;

terminal PAR_A, PAR_C, LLAVE_A, LLAVE_C;
terminal COMA, PUNTO_COMA, PUNTO;

terminal String ID;
terminal String CADENA;
terminal String CARACTER;
terminal Integer ENTERO;
terminal Double DECIMAL;

non terminal LinkedList<Instruccion> inicio, funcion_main, instrucciones;
non terminal Instruccion instruccion, declaracion, impresion;
non terminal Object expresion;
non terminal String tipo;
non terminal Instruccion if_instr;
non terminal Instruccion for_instr;
non terminal Instruccion actualizacion_for;
non terminal Instruccion incremento;
non terminal Instruccion decremento;
non terminal LinkedList<Object> lista_print;

precedence left OR;
precedence left AND;
precedence left IGUAL_IGUAL, DIFERENTE;
precedence left MENOR, MENOR_IGUAL, MAYOR, MAYOR_IGUAL;
precedence left MAS, MENOS;
precedence left POR, DIV, MOD;
precedence right NOT;
precedence right UMENOS;

start with inicio;

inicio ::= funcion_main:fm
        {: RESULT = fm; :}
        ;

funcion_main ::= FUNC MAIN PAR_A PAR_C LLAVE_A instrucciones:ins LLAVE_C
              {: RESULT = ins; :}
              ;

instrucciones ::= instrucciones:lista instruccion:ins
                {:
                    if (ins != null) {
                        lista.add(ins);
                    }
                    RESULT = lista;
                :}
                |
                {:
                    RESULT = new LinkedList<Instruccion>();
                :}
                ;

instruccion ::= declaracion:d
                {: RESULT = d; :}
              | impresion:i
                {: RESULT = i; :}
              | if_instr:i
                {: RESULT = i; :}
              | for_instr:f
                {: RESULT = f; :}
              | incremento:i
                {: RESULT = i; :}
              | decremento:d
                {: RESULT = d; :}
               //sirve para bloques
              | LLAVE_A instrucciones:l LLAVE_C
              {:
                  RESULT = new Bloque(l);
              :}
              | BREAK
                {: RESULT = new Break(); :}
              | CONTINUE
                {: RESULT = new Continue(); :}
              ;

incremento ::= ID:id INCREMENTO
{:
    RESULT = new Compuesta(id, 1, "+");
:}
;

decremento ::= ID:id DECREMENTO
{:
    RESULT = new Compuesta(id, 1, "-");
:}
;
               

if_instr ::= IF  expresion:condicion 
             LLAVE_A instrucciones:ins LLAVE_C
             {:
                RESULT = new If(condicion, ins, null);
             :}
           | IF  expresion:condicion 
             LLAVE_A instrucciones:ins_if LLAVE_C
             ELSE
             LLAVE_A instrucciones:ins_else LLAVE_C
             {:
                RESULT = new If(condicion, ins_if, ins_else);
             :}
            //error dentro del if
             | IF PAR_A error PAR_C LLAVE_A instrucciones:ins LLAVE_C
                {:
                    ReporteE.agregarError(
                        "SINTACTICO",
                        "Condición inválida dentro del if",
                        0,
                        0
                    );

                    RESULT = null;
                :}
            | IF PAR_A error PAR_C
                 LLAVE_A instrucciones:ins_if LLAVE_C
                 ELSE
                 LLAVE_A instrucciones:ins_else LLAVE_C
                 {:
                     ReporteE.agregarError(
                         "SINTACTICO",
                         "Condición inválida dentro del if",
                         0,
                         0
                     );

                     RESULT = null;
                 :}

           ;

for_instr ::=   FOR expresion:condicion
                LLAVE_A instrucciones:ins LLAVE_C
                {:
                    RESULT = new For(null, condicion, null, ins);
                :}
                | FOR declaracion:inicio PUNTO_COMA expresion:condicion PUNTO_COMA actualizacion_for:actualizacion
                LLAVE_A instrucciones:ins LLAVE_C
                {:
                  RESULT = new For(inicio, condicion, actualizacion, ins);
                :}
                | FOR error LLAVE_A instrucciones:ins LLAVE_C
                {:
                    ReporteE.agregarError(
                        "SINTACTICO",
                        "Condición inválida dentro del for",
                        0,
                        0
                    );

                    RESULT = null;
                :}
            ;



declaracion ::= VAR ID:id tipo:t IGUAL expresion:e
              {:
                  RESULT = new Declaracion(id, t, e);
              :}
              | VAR ID:id tipo:t
              {:
                  RESULT = new Declaracion(id, t, null);
              :}
              | ID:id DECLARACION expresion:e
              {:
                  String tipoInferido = "desconocido";

                  if (e instanceof Integer) tipoInferido = "int";
                  else if (e instanceof Double) tipoInferido = "float64";
                  else if (e instanceof String) tipoInferido = "string";
                  else if (e instanceof Boolean) tipoInferido = "bool";

                  RESULT = new Declaracion(id, tipoInferido, e);
              :}
                | ID:id IGUAL expresion:e
              {:
                  RESULT = new Asignacion(id, e);
              :}
              | ID:id MAS_IGUAL expresion:e
              {:
                  RESULT = new Compuesta(id, e, "+");
              :}

              | ID:id MENOS_IGUAL expresion:e
              {:
                  RESULT = new Compuesta(id, e, "-");
              :}

                ///produccion para error
                | VAR ID:id tipo:t IGUAL error
                {:
                    ReporteE.agregarError(
                        "SINTACTICO",
                        "Se esperaba una expresión después del '=' en la declaración de '" + id + "'",
                        0,
                        0
                    );

                    RESULT = null;
                :}
                      ;

actualizacion_for ::=
                      ID:id MAS_IGUAL expresion:valor
                      {:
                          RESULT = new Compuesta(id, valor,"+");
                      :}

                    | ID:id MENOS_IGUAL expresion:valor
                      {:
                          RESULT = new Compuesta(id, valor,"-");
                      :}

                    | ID:id IGUAL expresion:valor
                      {:
                          RESULT = new Asignacion(id, valor);
                      :}
                    | ID:id INCREMENTO
                        {: RESULT = new Compuesta(id, 1, "++"); :}

                      | ID:id DECREMENTO
                        {: RESULT = new Compuesta(id, 1, "--"); :}
                ;


tipo ::= INT
       {: RESULT = "int"; :}
       | FLOAT64
       {: RESULT = "float64"; :}
       | STRING
       {: RESULT = "string"; :}
       | BOOL
       {: RESULT = "bool"; :}
       | RUNE
       {: RESULT = "rune"; :}
       ;

impresion ::= PRINTLN PAR_A lista_print:e PAR_C
            {:
                RESULT = new Println(e);
            :}
            //para errores dentro de print.fm ejempo print(10+ )
            | PRINTLN PAR_A error PAR_C
            {:
                ReporteE.agregarError(
                    "SINTACTICO",
                    "Expresión inválida dentro de fmt.Println",
                    0,
                    0
                );

                RESULT = null;
            :}
            ;

lista_print ::=
      lista_print:l COMA expresion:e
      {:
          l.add(e);
          RESULT = l;
      :}

    | expresion:e
      {:
          LinkedList<Object> lista = new LinkedList<Object>();
          lista.add(e);
          RESULT = lista;
      :}
;

expresion ::= expresion:e1 MAS expresion:e2
            {: RESULT = new Operacion(e1, e2, "+"); :}

            | expresion:e1 MENOS expresion:e2
            {: RESULT = new Operacion(e1, e2, "-"); :}

            | expresion:e1 POR expresion:e2
            {: RESULT = new Operacion(e1, e2, "*"); :}

            | expresion:e1 DIV expresion:e2
            {: RESULT = new Operacion(e1, e2, "/"); :}

            | expresion:e1 MOD expresion:e2
            {: RESULT = new Operacion(e1, e2, "%"); :}
            
            | expresion:e1 MAYOR expresion:e2
            {: RESULT = new Operacion(e1, e2, ">"); :}

            | expresion:e1 MENOR expresion:e2
            {: RESULT = new Operacion(e1, e2, "<"); :}

            | expresion:e1 MAYOR_IGUAL expresion:e2
            {: RESULT = new Operacion(e1, e2, ">="); :}

            | expresion:e1 MENOR_IGUAL expresion:e2
            {: RESULT = new Operacion(e1, e2, "<="); :}

            | expresion:e1 IGUAL_IGUAL expresion:e2
            {: RESULT = new Operacion(e1, e2, "=="); :}

            | expresion:e1 DIFERENTE expresion:e2
            {: RESULT = new Operacion(e1, e2, "!="); :}

            | expresion:e1 AND expresion:e2
            {: RESULT = new Operacion(e1, e2, "&&"); :}

            | expresion:e1 OR expresion:e2
            {: RESULT = new Operacion(e1, e2, "||"); :}

            | NOT expresion:e
            {: RESULT = new Operacion(e, null, "!"); :}
            
            | MENOS expresion:e
            {: RESULT = new Operacion(0, e, "-"); :}
            %prec UMENOS
            
            | PAR_A expresion:e PAR_C
            {: RESULT = e; :}

            | ATOI PAR_A expresion:e PAR_C
            {:
                RESULT = new FuncionNativa("atoi", e);
            :}

            | PARSEFLOAT PAR_A expresion:e COMA expresion:n PAR_C
            {:
                RESULT = new FuncionNativa("parsefloat", e);
            :}

            | TYPEOF PAR_A expresion:e PAR_C DOTSTRING PAR_A PAR_C
            {:
                RESULT = new FuncionNativa("typeof", e);
            :}

            | ENTERO:e
            {: RESULT = e; :}

            | DECIMAL:e
            {: RESULT = e; :}

            | CADENA:e
            {: RESULT = e; :}

            | CARACTER:e
            {: RESULT = e; :}

            | TRUE
            {: RESULT = true; :}

            | FALSE
            {: RESULT = false; :}

            | NIL
            {: RESULT = null; :}

            | ID:id
            {: RESULT = new AccVariable(id); :}

            
            ;